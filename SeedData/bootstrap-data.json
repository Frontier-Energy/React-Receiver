      "etag": "\"hvac-v1\"",
      "schema": {
        "formName": "HVAC Inspection",
        "sections": [
          {
            "title": "Equipment Information",
            "fields": [
              {
                "id": "unitLocation",
                "label": "Unit Location",
                "type": "text",
                "required": true,
                "externalID": "hvac.unitLocation",
                "placeholder": "e.g., Attic, Basement, Roof",
                "validationRules": [
                  {
                    "type": "minLength",
                    "value": 3,
                    "message": "Unit location must be at least 3 characters"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "formType": "electrical",
