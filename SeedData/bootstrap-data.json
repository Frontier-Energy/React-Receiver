              {
                "id": "panelCondition",
                "label": "Panel Condition",
                "type": "select",
                "required": true,
                "externalID": "electrical.panelCondition",
                "options": [
                  {
                    "label": "Good",
                    "value": "good"
                  },
                  {
                    "label": "Needs Attention",
                    "value": "needs-attention"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
